# Qwen3-14B OpenAI-compatible server. Model weights mounted at runtime only.
# Remote build fetches script from GitHub raw (%post) — no %files upload needed.
# Build: REMOTE_BUILD=1 bash containers/build.sh qwen-server
Bootstrap: docker
From: nvidia/cuda:12.4.1-base-ubuntu22.04

%labels
    Author DeepRare
    Version 1.0
    Description Qwen3 transformers OpenAI API server for DeepRare

%environment
    export DEEPRARE_ROOT=/opt/deeprare
    export PATH=/opt/conda/envs/qwen3_infer/bin:$PATH
    export CONDA_DEFAULT_ENV=qwen3_infer
    export PYTHONUNBUFFERED=1
    export HF_HUB_OFFLINE=1
    export TRANSFORMERS_OFFLINE=1

%post
    set -eu
    export DEBIAN_FRONTEND=noninteractive

    mkdir -p /opt/deeprare/scripts

    apt-get update
    apt-get install -y --no-install-recommends ca-certificates curl wget bzip2
    rm -rf /var/lib/apt/lists/*

    wget -q -O /opt/deeprare/scripts/qwen_openai_server.py \
        "${DEEPRARE_GIT_RAW}/${DEEPRARE_GIT_REF}/scripts/qwen_openai_server.py"

    wget -q https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-x86_64.sh -O /tmp/miniforge.sh
    bash /tmp/miniforge.sh -b -p /opt/conda
    rm -f /tmp/miniforge.sh
    . /opt/conda/etc/profile.d/conda.sh

    conda create -n qwen3_infer python=3.10 -y
    conda activate qwen3_infer

    conda install -y -c conda-forge sentencepiece --no-update-deps

    pip install --no-cache-dir -U pip wheel
    pip install --no-cache-dir \
        torch==2.1.2 torchvision==0.16.2 torchaudio==2.1.2 \
        --index-url https://download.pytorch.org/whl/cu121

    cat >/tmp/pip-constraints.txt <<'EOF'
torch==2.1.2
torchvision==0.16.2
torchaudio==2.1.2
EOF

    # fp16 only in container (see run-qwen-server.sh); skip bitsandbytes — it upgrades torch to 2.12+.
    pip install --no-cache-dir -c /tmp/pip-constraints.txt \
        "numpy>=1.26,<2" \
        "transformers>=4.51.0,<5.0" \
        "tokenizers>=0.21,<0.22" \
        accelerate \
        tqdm \
        "huggingface_hub>=0.26,<1.0" \
        safetensors \
        regex \
        pyyaml \
        fastapi \
        uvicorn \
        pydantic \
        starlette \
        anyio \
        httpx \
        filelock \
        packaging \
        requests

    python -c "import torch, transformers; print('OK', torch.__version__, transformers.__version__)"

    pip cache purge
    conda clean -afy
    rm -rf /root/.cache
    rm -f /tmp/pip-constraints.txt

%runscript
    exec python /opt/deeprare/scripts/qwen_openai_server.py "$@"

%help
    Qwen3 OpenAI server. Mount local model directory (NOT inside the image):
      apptainer exec --nv \\
        -B /path/to/Qwen3-14B:/models/Qwen3-14B:ro \\
        qwen-server.sif \\
        --model /models/Qwen3-14B --port 8000 --host 0.0.0.0 --fp16
    Or: bash containers/run-qwen-server.sh
