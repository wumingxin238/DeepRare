# Copy to env.local and: source containers/env.local
#
# Local Qwen3-14B weights (HuggingFace snapshot on this server)
export QWEN_MODEL=/export/home/zhangzhuoyu/.cache/huggingface/hub/models--Qwen--Qwen3-14B/snapshots/40c069824f4251a91eefaf281ebe4c544efd3e18
export QWEN_MODEL_DIR=$QWEN_MODEL

# GPUs
export CUDA_VISIBLE_DEVICES=5          # qwen server
export INFER_GPU=0                     # deeprare BERT / exomiser subprocess

# xiaoai embedding only
export EMBED_APIKEY=sk-your-key
export EMBED_BASE_URL=https://xiaoai.plus/v1

# OpenAI model id must match qwen server --model (full snapshot path)
export QWEN_MODEL=$QWEN_MODEL_DIR

# Project root on host (database/, exomiser-cli-14.0.0/, data/vcf/ live here)
export DEEPRARE_WORK=/export/home/zhangzhuoyu/DeepRare

# Sylabs remote build (https://cloud.sylabs.io/library/wmx238)
export SYLABS_USER=wmx238
export SYLABS_COLLECTION=deeprare
# Use Library URI if local pull failed (401 on PRIVATE repos):
# export QWEN_SIF=library://wmx238/deeprare/qwen-server:latest
